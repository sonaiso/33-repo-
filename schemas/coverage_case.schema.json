{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Computed Coverage Case Schema",
  "description": "trace_ref: docs/09_COMPUTED_COVERAGE_CONSTITUTION.md Coverage Schema-Only Law. Runtime embargo reference: docs/12_RUNTIME_EMBARGO_CONSTITUTION.md. Domain values are expected-case labels only and do not open runtime domains.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "input_text",
    "source_domain",
    "target_domain",
    "source_contract",
    "target_contract",
    "expected_verdict",
    "forbidden_outputs",
    "trace_ref"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "input_text": {
      "type": "string",
      "minLength": 1
    },
    "source_domain": {
      "type": "string",
      "description": "Source-domain label for schema-only expected cases under Runtime Embargo.",
      "enum": [
        "D1_DAL_ONLY",
        "D2_LAFZI_FORM",
        "D3_LEXICAL_MADLUL",
        "D4_RELATION",
        "D5_IFADAH",
        "D6_HUKM",
        "D7_TANZIL"
      ]
    },
    "target_domain": {
      "type": "string",
      "description": "Target-domain label for schema-only expected cases under Runtime Embargo.",
      "enum": [
        "D1_DAL_ONLY",
        "D2_LAFZI_FORM",
        "D3_LEXICAL_MADLUL",
        "D4_RELATION",
        "D5_IFADAH",
        "D6_HUKM",
        "D7_TANZIL"
      ]
    },
    "source_contract": {
      "type": "string",
      "description": "Constitutional document or contract reference governing the source-domain label under Runtime Embargo.",
      "minLength": 1
    },
    "target_contract": {
      "type": "string",
      "description": "Constitutional document or contract reference governing the target-domain label under Runtime Embargo.",
      "minLength": 1
    },
    "expected_verdict": {
      "type": "string",
      "description": "Expected verdict label only; no computed verdict is accepted before explicit runtime authorization.",
      "enum": [
        "EXPECTED_ACCEPTED_CANDIDATE",
        "EXPECTED_BLOCKED",
        "EXPECTED_RESIDUAL",
        "EXPECTED_BRIDGE_REQUIRED",
        "EXPECTED_PROOF_REQUIRED"
      ]
    },
    "required_bridges": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_proof_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "MRKProof",
          "IdentityProof",
          "GateProof",
          "BridgeProof",
          "EvidenceProof",
          "CoverageProof"
        ],
        "minLength": 1
      }
    },
    "expected_failure_family": {
      "type": "string",
      "minLength": 1
    },
    "expected_residual_policy": {
      "type": "string",
      "minLength": 1
    },
    "forbidden_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "trace_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "not": {
    "anyOf": [
      {
        "required": [
          "computed_verdict"
        ]
      },
      {
        "required": [
          "dashboard_total"
        ]
      },
      {
        "required": [
          "manual_dashboard"
        ]
      },
      {
        "required": [
          "mrk_defaults"
        ]
      },
      {
        "required": [
          "domain_proved"
        ]
      },
      {
        "required": [
          "unit_proved"
        ]
      },
      {
        "required": [
          "identity_preserved"
        ]
      },
      {
        "required": [
          "trace_preserved"
        ]
      },
      {
        "required": [
          "gate_passed"
        ]
      },
      {
        "required": [
          "is_preserved"
        ]
      },
      {
        "properties": {
          "rank": {
            "enum": [
              "CERTIFICATE",
              "REJECTED"
            ]
          }
        },
        "required": [
          "rank"
        ]
      },
      {
        "properties": {
          "authoritative": {
            "const": true
          }
        },
        "required": [
          "authoritative"
        ]
      }
    ]
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_BLOCKED"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "expected_failure_family"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_RESIDUAL"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "expected_residual_policy"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_BRIDGE_REQUIRED"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "required_bridges"
        ],
        "properties": {
          "required_bridges": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_PROOF_REQUIRED"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "required_proof_kinds"
        ],
        "properties": {
          "required_proof_kinds": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "MRKProof",
                "IdentityProof",
                "GateProof",
                "BridgeProof",
                "EvidenceProof",
                "CoverageProof"
              ],
              "minLength": 1
            },
            "minItems": 1
          }
        }
      }
    }
  ]
}
