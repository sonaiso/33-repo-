{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Computed Coverage Case Schema",
  "description": "trace_ref: docs/18_COMPUTED_COVERAGE_SCHEMA_CONSTITUTION.md Schema-only constitutional contract under runtime embargo.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "input_text",
    "input_domain",
    "expected_verdict",
    "required_contracts",
    "trace_ref"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "input_text": {
      "type": "string",
      "minLength": 1
    },
    "input_domain": {
      "type": "string",
      "minLength": 1
    },
    "expected_verdict": {
      "type": "string",
      "description": "Expected verdict label only; computed verdict fields are forbidden under embargo.",
      "enum": [
        "EXPECTED_ACCEPTED_CANDIDATE",
        "EXPECTED_BLOCKED",
        "EXPECTED_RESIDUAL",
        "EXPECTED_BRIDGE_REQUIRED",
        "EXPECTED_PROOF_REQUIRED"
      ]
    },
    "required_contracts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "required_bridges": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_failure_family": {
      "type": "string",
      "minLength": 1
    },
    "expected_residual_policy": {
      "type": "string",
      "minLength": 1
    },
    "trace_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "not": {
    "anyOf": [
      {
        "required": [
          "computed_verdict"
        ]
      },
      {
        "required": [
          "dashboard_total"
        ]
      },
      {
        "required": [
          "manual_dashboard"
        ]
      },
      {
        "required": [
          "mrk_defaults"
        ]
      },
      {
        "required": [
          "domain_proved"
        ]
      },
      {
        "required": [
          "unit_proved"
        ]
      },
      {
        "required": [
          "identity_preserved"
        ]
      },
      {
        "required": [
          "trace_preserved"
        ]
      },
      {
        "required": [
          "gate_passed"
        ]
      },
      {
        "required": [
          "coverage_matrix_v0.1.yaml"
        ]
      },
      {
        "properties": {
          "is_preserved": {}
        },
        "required": [
          "is_preserved"
        ]
      },
      {
        "properties": {
          "rank": {
            "enum": [
              "CERTIFICATE",
              "REJECTED"
            ]
          }
        },
        "required": [
          "rank"
        ]
      },
      {
        "properties": {
          "authoritative": {
            "const": true
          }
        },
        "required": [
          "authoritative"
        ]
      },
      {
        "properties": {
          "rank": {
            "const": "Rank.\\u0043ERTIFICATE"
          }
        },
        "required": [
          "rank"
        ]
      },
      {
        "properties": {
          "rank": {
            "const": "Rank.\\u0052EJECTED"
          }
        },
        "required": [
          "rank"
        ]
      }
    ]
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_BLOCKED"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "expected_failure_family"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_RESIDUAL"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "expected_residual_policy"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "const": "EXPECTED_BRIDGE_REQUIRED"
          }
        },
        "required": [
          "expected_verdict"
        ]
      },
      "then": {
        "required": [
          "required_bridges"
        ],
        "properties": {
          "required_bridges": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "expected_verdict": {
            "enum": [
              "EXPECTED_BLOCKED",
              "EXPECTED_PROOF_REQUIRED"
            ]
          }
        }
      },
      "then": {
        "required": [
          "expected_failure_family"
        ]
      }
    }
  ]
}
