{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runtime Embargo Lift Request Schema",
  "description": "trace_ref: docs/18_RUNTIME_EMBARGO_LIFT_PROTOCOL.md Request-shape schema only; no runtime authorization.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "properties": {
        "negative_tests": {
          "allOf": [
            {
              "contains": {
                "const": "reject-rank-certificate"
              }
            },
            {
              "contains": {
                "const": "reject-rank-rejected"
              }
            },
            {
              "contains": {
                "const": "reject-boolean-as-proof"
              }
            },
            {
              "contains": {
                "const": "reject-evidence-list-as-proof"
              }
            },
            {
              "contains": {
                "const": "reject-domain-open-without-bridge"
              }
            },
            {
              "contains": {
                "const": "reject-manual-computed-verdict"
              }
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "lift_type": {
            "enum": [
              "LIFT_TYPE_SCHEMA_RUNTIME",
              "LIFT_TYPE_PROOF_EVALUATOR",
              "LIFT_TYPE_BRIDGE_EVALUATOR",
              "LIFT_TYPE_COVERAGE_RUNNER",
              "LIFT_TYPE_KERNEL"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "domain_opening": {
            "const": "none"
          }
        }
      }
    },
    {
      "properties": {
        "authorized_artifacts": {
          "not": {
            "contains": {
              "enum": [
                "src/taaqqul_slot_geometry/L1/binding_kernel.py",
                "src/taaqqul_slot_geometry/L1/decision_engine.py",
                "src/taaqqul_slot_geometry/runtime/binding_kernel.py",
                "src/taaqqul_slot_geometry/runtime/decision_engine.py",
                "src/taaqqul_slot_geometry/core/binding_kernel.py",
                "src/taaqqul_slot_geometry/core/decision_engine.py",
                "coverage_matrix_v0.1.yaml",
                "docs/coverage_matrix_v0.1.yaml",
                "data/coverage_matrix_v0.1.yaml",
                "schemas/coverage_matrix_v0.1.yaml",
                "tests/test_binding_constraints.py",
                "l_protocol/engine/binding_kernel.py",
                "l_protocol/engine/decision_engine.py",
                "l_protocol/contracts/binding_instructions.py",
                "l_protocol/coverage_matrix_v0.1.yaml",
                "l_protocol/tests/test_binding_constraints.py"
              ]
            }
          }
        }
      }
    },
    {
      "properties": {
        "non_scope_artifacts": {
          "description": "Must explicitly acknowledge the full canonical forbidden runtime artifact set from data/forbidden_runtime_artifacts.json.",
          "allOf": [
            {
              "contains": {
                "const": "src/taaqqul_slot_geometry/L1/binding_kernel.py"
              }
            },
            {
              "contains": {
                "const": "src/taaqqul_slot_geometry/L1/decision_engine.py"
              }
            },
            {
              "contains": {
                "const": "src/taaqqul_slot_geometry/runtime/binding_kernel.py"
              }
            },
            {
              "contains": {
                "const": "src/taaqqul_slot_geometry/runtime/decision_engine.py"
              }
            },
            {
              "contains": {
                "const": "src/taaqqul_slot_geometry/core/binding_kernel.py"
              }
            },
            {
              "contains": {
                "const": "src/taaqqul_slot_geometry/core/decision_engine.py"
              }
            },
            {
              "contains": {
                "const": "coverage_matrix_v0.1.yaml"
              }
            },
            {
              "contains": {
                "const": "docs/coverage_matrix_v0.1.yaml"
              }
            },
            {
              "contains": {
                "const": "data/coverage_matrix_v0.1.yaml"
              }
            },
            {
              "contains": {
                "const": "schemas/coverage_matrix_v0.1.yaml"
              }
            },
            {
              "contains": {
                "const": "tests/test_binding_constraints.py"
              }
            },
            {
              "contains": {
                "const": "l_protocol/engine/binding_kernel.py"
              }
            },
            {
              "contains": {
                "const": "l_protocol/engine/decision_engine.py"
              }
            },
            {
              "contains": {
                "const": "l_protocol/contracts/binding_instructions.py"
              }
            },
            {
              "contains": {
                "const": "l_protocol/coverage_matrix_v0.1.yaml"
              }
            },
            {
              "contains": {
                "const": "l_protocol/tests/test_binding_constraints.py"
              }
            }
          ]
        }
      }
    },
    {
      "properties": {
        "authorized_artifacts": {
          "items": {
            "not": {
              "pattern": "(^|/)(binding_kernel|decision_engine)\\.py$|(^|/)coverage_matrix_v0\\.1\\.yaml$"
            }
          }
        }
      }
    }
  ],
  "required": [
    "lift_type",
    "authorized_artifacts",
    "non_scope_artifacts",
    "readiness_ledger_source",
    "residual_blockers_acknowledged",
    "rollback_plan",
    "negative_tests",
    "domain_opening",
    "rank_policy",
    "blanket_lift"
  ],
  "properties": {
    "lift_type": {
      "type": "string",
      "enum": [
        "LIFT_TYPE_SCHEMA_RUNTIME",
        "LIFT_TYPE_PROOF_EVALUATOR",
        "LIFT_TYPE_BRIDGE_EVALUATOR",
        "LIFT_TYPE_COVERAGE_RUNNER",
        "LIFT_TYPE_KERNEL"
      ]
    },
    "authorized_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "Repo-relative canonical path only: no absolute paths, no leading './', no leading/trailing whitespace, no backslashes, no '.' or '..' segments, no empty segments ('//'), no trailing slash, and no glob wildcards.",
        "$comment": "No leading slash (absolute paths), no leading './', no leading/trailing whitespace, no backslashes anywhere, no '.' or '..' path segments, no consecutive slashes (empty segments), no trailing slash, and no glob wildcards.",
        "pattern": "^(?!/)(?!\\.\\/)(?!\\s)(?!.*\\s$)(?!.*\\\\)(?!.*(?:^|/)\\.(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\/$)(?!.*[*?\\[\\]{}]).+$"
      }
    },
    "non_scope_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "Repo-relative canonical path only: no absolute paths, no leading './', no leading/trailing whitespace, no backslashes, no '.' or '..' segments, no empty segments ('//'), no trailing slash, and no glob wildcards.",
        "$comment": "No leading slash (absolute paths), no leading './', no leading/trailing whitespace, no backslashes anywhere, no '.' or '..' path segments, no consecutive slashes (empty segments), no trailing slash, and no glob wildcards.",
        "pattern": "^(?!/)(?!\\.\\/)(?!\\s)(?!.*\\s$)(?!.*\\\\)(?!.*(?:^|/)\\.(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\/$)(?!.*[*?\\[\\]{}]).+$"
      }
    },
    "readiness_ledger_source": {
      "type": "string",
      "const": "docs/17_RUNTIME_EMBARGO_READINESS_LEDGER.md"
    },
    "residual_blockers_acknowledged": {
      "type": "boolean",
      "const": true
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 1
    },
    "negative_tests": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "domain_opening": {
      "type": "string",
      "enum": [
        "none",
        "D3_LEXICAL_MADLUL",
        "D4_RELATION",
        "D5_IFADAH",
        "D6_HUKM",
        "D7_TANZIL"
      ]
    },
    "rank_policy": {
      "type": "string",
      "const": "CANDIDATE_ONLY"
    },
    "blanket_lift": {
      "type": "boolean",
      "const": false
    },
    "authorization_source": {
      "type": "string",
      "const": "explicit_runtime_embargo_lift_pr",
      "description": "Audit-only discriminator: prompts, user delegation, agent responses, and readiness status are not lift authority."
    },
    "pr_marker": {
      "type": "string",
      "pattern": "^Runtime Embargo Lift PR #[0-9]+$",
      "description": "Audit-only explicit Runtime Embargo Lift PR marker with PR number."
    },
    "failure_alignment_reference": {
      "type": "string",
      "const": "docs/13_FAILURE_ALIGNMENT_CONSTITUTION.md"
    },
    "proof_policy_reference": {
      "type": "string",
      "const": "docs/08_PROOF_OBJECT_CONSTITUTION.md"
    },
    "artifact_authorization_scope": {
      "type": "string",
      "const": "exact_artifacts_only"
    },
    "requested_runtime_surface": {
      "type": "string",
      "enum": [
        "schema_only",
        "proof_evaluator",
        "bridge_evaluator",
        "coverage_runner"
      ],
      "description": "Audit-only runtime surface label; kernel/decision engine by default is not accepted."
    }
  }
}
